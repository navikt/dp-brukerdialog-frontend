{
  "$schema": "https://inlang.com/schema/project-settings",
  "baseLocale": "nb",
  "locales": ["nb", "en", "nn"],

  "sourceLanguageTag": "nb",
  "languageTags": ["nb", "en", "nn"],

  "modules": ["https://cdn.jsdelivr.net/npm/@inlang/plugin-i18next@latest/dist/index.js"],
  "plugin.inlang.i18next": {
    "pathPattern": {
      "common": "./public/locales/{languageTag}/common.json",
      "soknadOversikt": "./public/locales/{languageTag}/soknadOversikt.json"
    },
    "variableReferencePattern": ["{{", "}}"]
  }
}
