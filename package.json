{
  "name": "dp-brukerdialog-frontend",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "copy-env": "cp .env.example .env",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "token": "node ./token-generator.cjs",
    "prepare": "husky",
    "test": "vitest --run",
    "coverage": "vitest run --coverage",
    "dependabot": "react-router typegen && tsc && vitest --run"
  },
  "dependencies": {
    "@elastic/ecs-pino-format": "1.5.0",
    "@grafana/faro-web-sdk": "2.6.3",
    "@grafana/faro-web-tracing": "2.6.3",
    "@navikt/aksel-icons": "8.10.6",
    "@navikt/ds-css": "8.10.6",
    "@navikt/ds-react": "8.10.6",
    "@navikt/nav-dekoratoren-moduler": "4.1.1",
    "@navikt/oasis": "4.1.4",
    "@portabletext/react": "6.2.0",
    "@portabletext/to-html": "^5.0.2",
    "@portabletext/types": "4.0.2",
    "@react-router/fs-routes": "7.15.1",
    "@react-router/node": "7.15.1",
    "@react-router/serve": "^7.15.1",
    "@remix-run/form-data-parser": "0.17.0",
    "@rvf/react-router": "8.1.2",
    "@rvf/zod": "7.0.5",
    "@sanity/client": "7.22.0",
    "classnames": "2.5.1",
    "date-fns": "4.2.1",
    "html-react-parser": "6.1.1",
    "i18n-iso-countries": "7.14.0",
    "isbot": "5.1.40",
    "msw": "2.14.6",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "prom-client": "15.1.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router": "7.15.1",
    "sanitize-html": "^2.17.4",
    "tiny-invariant": "1.3.3",
    "uuid": "^14.0.0",
    "vite-plugin-devtools-json": "1.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@inquirer/prompts": "8.4.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@react-router/dev": "^7.15.1",
    "@types/node": "^25.9.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@typescript-eslint/eslint-plugin": "8.59.4",
    "@typescript-eslint/parser": "8.59.4",
    "@vitest/coverage-v8": "4.1.6",
    "@vitest/ui": "4.1.6",
    "autoprefixer": "10.5.0",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "husky": "9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "17.0.5",
    "prettier": "3.8.3",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.6"
  },
  "engines": {
    "node": ">=24.11.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  }
}
